# Create sequences
def make_sequences(Tmax_n, Tmin_n, lookback, horizon):
    combined = np.stack([Tmax_n, Tmin_n], axis=-1)   # (days, 31, 31, 2)
    n = combined.shape[0]
    X, y = [], []
    for i in range(n - lookback - horizon + 1):
        X.append(combined[i:i+lookback])
        y.append(combined[i+lookback:i+lookback+horizon])
    return np.array(X, dtype=np.float32), np.array(y, dtype=np.float32)

print(" Creating sequences (thoda time lagega)...")
X, y = make_sequences(T_max_n, T_min_n, cfg.LOOKBACK, cfg.HORIZON)
print(f"   X : {X.shape}  → (samples, {cfg.LOOKBACK}days, 31, 31, 2ch)")
print(f"   y : {y.shape}  → (samples, {cfg.HORIZON}days, 31, 31, 2ch)")

# Train / Val / Test split
n        = len(X)
n_test   = int(n * cfg.TEST_SPLIT)
n_val    = int(n * cfg.VAL_SPLIT)
n_train  = n - n_val - n_test

X_train, y_train = X[:n_train],               y[:n_train]
X_val,   y_val   = X[n_train:n_train+n_val],  y[n_train:n_train+n_val]
X_test,  y_test  = X[n_train+n_val:],         y[n_train+n_val:]

print(f"\n Split → Train:{n_train} | Val:{n_val} | Test:{n_test}")
print(f"   Train covers ~{n_train/365:.1f} years of data")
print(" Preprocessing complete!")


# ============================================================
# MODEL  — ConvLSTM2D Architecture
# ============================================================

def build_model(lookback, rows, cols, channels=2, horizon=7):
    inp = layers.Input(shape=(lookback, rows, cols, channels))

    x = layers.ConvLSTM2D(64, (3,3), padding='same', return_sequences=True,
                           activation='tanh', recurrent_activation='sigmoid',
                           dropout=0.1, recurrent_dropout=0.1)(inp)
    x = layers.BatchNormalization()(x)

    x = layers.ConvLSTM2D(64, (3,3), padding='same', return_sequences=True,
                           activation='tanh', recurrent_activation='sigmoid',
                           dropout=0.1, recurrent_dropout=0.1)(x)
    x = layers.BatchNormalization()(x)

    x = layers.ConvLSTM2D(32, (3,3), padding='same', return_sequences=True,
                           activation='tanh', recurrent_activation='sigmoid')(x)
    x = layers.BatchNormalization()(x)

    # Last `horizon` timesteps
    x = x[:, -horizon:, :, :, :]

    # Decoder
    x = layers.TimeDistributed(layers.Conv2D(32, (3,3), padding='same', activation='relu'))(x)
    x = layers.TimeDistributed(layers.Conv2D(16, (3,3), padding='same', activation='relu'))(x)
    out = layers.TimeDistributed(layers.Conv2D(channels, (1,1), padding='same', activation='sigmoid'))(x)

    model = keras.Model(inp, out, name='ConvLSTM_TempPredictor')
    return model

model = build_model(cfg.LOOKBACK, cfg.GRID_ROWS, cfg.GRID_COLS, 2, cfg.HORIZON)
model.compile(optimizer=keras.optimizers.Adam(cfg.LR), loss='mse', metrics=['mae'])
model.summary()
