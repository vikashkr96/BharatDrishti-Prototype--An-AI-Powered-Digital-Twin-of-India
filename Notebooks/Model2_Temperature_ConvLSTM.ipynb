# ============================================================
# BINARY FILE READER  (IMD float32 format)
# ============================================================

def read_imd_binary(filepath: Path,
                    rows: int = 31, cols: int = 31) -> np.ndarray:
    """
    Read full year binary file from IMD.

    IMD binary format:
      - Each value  = 4-byte float32
      - Each day    = rows × cols float32 values (31×31 = 961 values)
      - File        = all days of the year stacked sequentially
      - Missing     = -999.0  → replaced with NaN

    Returns: np.ndarray shape (n_days, rows, cols)
    """
    floats_per_day = rows * cols
    bytes_per_day  = floats_per_day * 4

    file_size = filepath.stat().st_size
    n_days    = file_size // bytes_per_day

    with open(filepath, 'rb') as f:
        raw = f.read()

    data = np.frombuffer(raw[:n_days * bytes_per_day],
                         dtype=np.float32).reshape(n_days, rows, cols)
    data = data.astype(np.float64)
    data[data == -999.0] = np.nan
    return data


def get_filepath(var: str, year: int, cfg) -> Path:
    if var == 'max':
        return cfg.MAX_DIR / f"{cfg.MAX_PREFIX}{year}{cfg.FILE_EXT}"
    else:
        return cfg.MIN_DIR / f"{cfg.MIN_PREFIX}{year}{cfg.FILE_EXT}"


print(" Binary reader defined")
print(f"   Bytes per day  = {31*31*4} bytes")
print(f"   Bytes per year ≈ {31*31*4*365/1024:.0f} KB")

