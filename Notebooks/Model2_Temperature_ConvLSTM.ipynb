results = {}
for ch, name in enumerate(['T_max', 'T_min']):
    yt = y_true[..., ch].flatten()
    yp = y_pred[..., ch].flatten()
    mask = (yt > -50) & (yt < 60)
    yt, yp = yt[mask], yp[mask]

    rmse = np.sqrt(mean_squared_error(yt, yp))
    mae  = mean_absolute_error(yt, yp)
    bias = np.mean(yp - yt)
    corr = np.corrcoef(yt, yp)[0,1]
    results[name] = dict(RMSE=rmse, MAE=mae, Bias=bias, Corr=corr)

    ok = " TARGET MET" if rmse < cfg.TARGET_RMSE else "⚠️  Above target"
    print(f"\n{'='*45}")
    print(f"  {name}  {ok}")
    print(f"  RMSE : {rmse:.3f}°C  (target <{cfg.TARGET_RMSE}°C)")
    print(f"  MAE  : {mae:.3f}°C")
    print(f"  Bias : {bias:+.3f}°C")
    print(f"  Corr : {corr:.4f}")

