def load_all_data(cfg):
    max_all, min_all = [], []

    for year in tqdm(range(cfg.YEAR_START, cfg.YEAR_END+1), desc="Loading years"):
        n_days = 366 if calendar.isleap(year) else 365

        # --- MAX TEMP ---
        fp_max = get_filepath('max', year, cfg)
        if fp_max.exists() and fp_max.stat().st_size > 1000:
            grids_max = read_imd_binary(fp_max, cfg.GRID_ROWS, cfg.GRID_COLS)
            # Pad/trim to exact n_days
            if grids_max.shape[0] < n_days:
                pad = np.full((n_days - grids_max.shape[0], cfg.GRID_ROWS, cfg.GRID_COLS), np.nan)
                grids_max = np.concatenate([grids_max, pad], axis=0)
            grids_max = grids_max[:n_days]
        else:
            print(f"     {fp_max.name} not found — using synthetic")
            grids_max = generate_synthetic_temp(n_days, 'max', cfg.GRID_ROWS, cfg.GRID_COLS, year)

        # --- MIN TEMP ---
        fp_min = get_filepath('min', year, cfg)
        if fp_min.exists() and fp_min.stat().st_size > 1000:
            grids_min = read_imd_binary(fp_min, cfg.GRID_ROWS, cfg.GRID_COLS)
            if grids_min.shape[0] < n_days:
                pad = np.full((n_days - grids_min.shape[0], cfg.GRID_ROWS, cfg.GRID_COLS), np.nan)
                grids_min = np.concatenate([grids_min, pad], axis=0)
            grids_min = grids_min[:n_days]
        else:
            print(f"     {fp_min.name} not found — using synthetic")
            grids_min = generate_synthetic_temp(n_days, 'min', cfg.GRID_ROWS, cfg.GRID_COLS, year)

        max_all.append(grids_max)
        min_all.append(grids_min)

    T_max = np.concatenate(max_all, axis=0)
    T_min = np.concatenate(min_all, axis=0)
    return T_max, T_min

