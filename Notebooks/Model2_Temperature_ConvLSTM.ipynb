# ============================================================
# SYNTHETIC DATA FALLBACK
# (Used only if .bin files are missing — realistic India climate)
# ============================================================

def generate_synthetic_temp(n_days: int, var: str,
                             rows: int = 31, cols: int = 31,
                             year_start: int = 2000) -> np.ndarray:
    lats = np.linspace(cfg.LAT_START, cfg.LAT_END, rows)
    lons = np.linspace(cfg.LON_START, cfg.LON_END, cols)
    LON_G, LAT_G = np.meshgrid(lons, lats)

    lat_grad    = 35.0 - 0.4  * (LAT_G - 7.5)
    desert      =  4.0 * np.exp(-((LAT_G-26)**2 + (LON_G-72)**2) / 40)
    himalaya    = -8.0 * np.exp(-((LAT_G-32)**2 + (LON_G-80)**2) / 20)
    coastal     = -2.0 * np.exp(-np.minimum(LON_G-67.5, 97.5-LON_G) / 5)
    T_base      = lat_grad + desert + himalaya + coastal

    grids = []
    for d in range(n_days):
        doy      = (d % 365) + 1
        yr_f     = year_start + d / 365.25
        seasonal = 8.0 * np.sin(2*np.pi*(doy-45)/365)
        monsoon  = -(5+2*(LON_G-67.5)/30) * np.exp(-((doy-182)**2)/(2*45**2))
        enso     = 1.5 * np.sin(2*np.pi*yr_f/3.7)
        noise    = uniform_filter(np.random.normal(0, 0.8, (rows,cols)), size=3)
        T        = T_base + seasonal + monsoon + enso + noise
        if var == 'min':
            T -= np.random.uniform(6, 10)
        grids.append(np.clip(T, -5, 55).astype(np.float32))

    return np.stack(grids, axis=0)

print(" Synthetic fallback ready (encodes monsoon, ENSO, lat gradient)")



