# INFERENCE FUNCTION (plug into Digital Twin pipeline)
# ============================================================

# Denormalize function
def denormalize(data, norm_val):
    return data * norm_val

def predict_temperature(model, last30_max: np.ndarray,
                        last30_min: np.ndarray) -> dict:
    """
    Predict next 7 days of Max & Min temperature grids.

    Parameters
    ----------
    last30_max : np.ndarray (30, 31, 31) — last 30 days T_max in °C
    last30_min : np.ndarray (30, 31, 31) — last 30 days T_min in °C

    Returns
    -------
    dict: {'T_max': (7,31,31), 'T_min': (7,31,31), 'dates': [...]}
    """
    Xn = np.stack([last30_max / cfg.NORMALIZE_BY,
                   last30_min / cfg.NORMALIZE_BY], axis=-1)[np.newaxis].astype(np.float32)
    yn = model.predict(Xn, verbose=0)[0]
    y  = yn * cfg.NORMALIZE_BY
    return {
        'T_max' : y[:,:,:,0],
        'T_min' : y[:,:,:,1],
        'dates' : [f"Day+{i+1}" for i in range(cfg.HORIZON)]
    }

# --- Demo inference ---
last30_max = denormalize(X_test[-1, :, :, :, 0], cfg.NORMALIZE_BY)
last30_min = denormalize(X_test[-1, :, :, :, 1], cfg.NORMALIZE_BY)

forecast = predict_temperature(model, last30_max, last30_min)

print(" 7-Day Forecast (India mean):")
for i, d in enumerate(forecast['dates']):
    mean_max = np.nanmean(forecast['T_max'][i])
    mean_min = np.nanmean(forecast['T_min'][i])
    print(f"   {d}: T_max={mean_max:.1f}°C | T_min={mean_min:.1f}°C")

# Delhi forecast
delhi_lat = int((28.6 - cfg.LAT_START) / (cfg.LAT_END - cfg.LAT_START) * (cfg.GRID_ROWS-1))
delhi_lon = int((77.2 - cfg.LON_START) / (cfg.LON_END - cfg.LON_START) * (cfg.GRID_COLS-1))

print("\n Delhi (28.6°N, 77.2°E) Forecast:")
for i, d in enumerate(forecast['dates']):
    tmax = forecast['T_max'][i, delhi_lat, delhi_lon]
    tmin = forecast['T_min'][i, delhi_lat, delhi_lon]
    print(f"   {d}: T_max={tmax:.1f}°C | T_min={tmin:.1f}°C")

