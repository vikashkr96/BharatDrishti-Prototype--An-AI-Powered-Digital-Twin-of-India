def fill_missing(data: np.ndarray) -> np.ndarray:
    """Linear interpolation per pixel for NaN values"""
    out = data.copy()
    n, r, c = out.shape
    for i in range(r):
        for j in range(c):
            s = pd.Series(out[:, i, j])
            out[:, i, j] = s.interpolate(method='linear',
                                          limit_direction='both').values
    return out

